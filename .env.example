# Kiwix reader exposed port
KIWIX_PORT=8080

# Admin panel exposed port
ADMIN_PORT=8081

# Default cron schedule (every Sunday at 3 AM)
DEFAULT_CRON=0 3 * * 0

# Max ZIM file versions to keep per language
DEFAULT_MAX_VERSIONS=3

# Host directory for ZIM file storage.
# Relative paths resolve against the docker-compose.yml location.
# For a home server, point this at a disk with enough space, e.g. /mnt/storage/zim
ZIM_DATA_HOST=./data/zim

# Host directory for the SQLite database.
DB_DATA_HOST=./data/db
